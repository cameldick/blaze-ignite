// Blaze Ignite data model.
// Postgres is the source of truth for idempotency (Event) and analytics.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// A creator account (one human, may own multiple channels).
model User {
  id        String   @id @default(cuid())
  blazeId   String   @unique
  username  String
  email     String?
  avatarUrl String?
  createdAt DateTime @default(now())
  channels  Channel[]
}

/// A connected Blaze channel. Holds encrypted OAuth tokens.
model Channel {
  id              String   @id @default(cuid())
  blazeChannelId  String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId          String
  displayName     String
  /// AES-GCM encrypted at rest; never returned to the client.
  accessTokenEnc  String
  refreshTokenEnc String?
  tokenExpiresAt  DateTime?
  scopes          String[]
  /// Rotating public token used in overlay URLs (revocable without OAuth churn).
  overlayToken    String   @unique @default(cuid())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  rules       ActionRule[]
  events      Event[]
  goals       Goal[]
  tipWars     TipWar[]
  bosses      Boss[]
  predictions Prediction[]
  oracles     Oracle[]

  @@index([userId])
}

/// Raw normalized event log. Idempotency + analytics source of truth.
/// Blaze money events carry no currency or tx hash; `amount` is unitless.
/// `actorAddress` holds the voter wallet on `vote` events.
model Event {
  id            String   @id @default(cuid())
  channel       Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  channelId     String
  /// Upstream-stable id; dedupe key together with channelId + kind.
  sourceEventId String
  kind          String
  actorId       String?
  actorName     String?
  actorAddress  String?
  amount        Float?
  message       String?
  occurredAt    DateTime
  receivedAt    DateTime @default(now())
  /// Full normalized event payload for replay/debug.
  payload       Json

  @@unique([channelId, kind, sourceEventId])
  @@index([channelId, occurredAt])
  @@index([channelId, kind])
}

/// Creator-authored tip -> action mapping (see shared/rules.ts ActionRule).
model ActionRule {
  id        String   @id @default(cuid())
  channel   Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  channelId String
  enabled   Boolean  @default(true)
  priority  Int      @default(100)
  /// RuleMatch JSON.
  match     Json
  /// ActionConfig JSON (discriminated by `type`).
  action    Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([channelId, enabled])
}

model Goal {
  id        String   @id @default(cuid())
  channel   Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  channelId String
  title     String
  target    Float
  current   Float    @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([channelId, active])
}

model TipWar {
  id        String          @id @default(cuid())
  channel   Channel         @relation(fields: [channelId], references: [id], onDelete: Cascade)
  channelId String
  title     String
  active    Boolean         @default(true)
  createdAt DateTime        @default(now())
  options   TipWarOption[]

  @@index([channelId, active])
}

model TipWarOption {
  id      String  @id @default(cuid())
  war     TipWar  @relation(fields: [warId], references: [id], onDelete: Cascade)
  warId   String
  label   String
  /// Optional keyword in a thanks message that routes support to this option.
  keyword String?
  total   Float   @default(0)

  @@index([warId])
}

model Boss {
  id            String   @id @default(cuid())
  channel       Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  channelId     String
  name          String
  maxHp         Float
  hp            Float
  rewardText    String?
  defeated      Boolean  @default(false)
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())

  @@index([channelId, active])
}

/// "Call It" prediction: viewers pick an outcome free via chat or back it with
/// Thanks (high-roller). Lifecycle: open -> locked -> resolved.
model Prediction {
  id              String   @id @default(cuid())
  channel         Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  channelId       String
  title           String
  /// open | locked | resolved
  status          String   @default("open")
  winningOptionId String?
  createdAt       DateTime @default(now())
  options         PredictionOption[]
  entries         PredictionEntry[]

  @@index([channelId, status])
}

model PredictionOption {
  id           String     @id @default(cuid())
  prediction   Prediction @relation(fields: [predictionId], references: [id], onDelete: Cascade)
  predictionId String
  label        String
  /// Chat/Thanks keyword that routes a pick to this option (e.g. "yes").
  keyword      String
  /// Distinct participants who chose this option.
  backers      Int        @default(0)
  /// Sum of Thanks staked on this option (high-roller weight).
  thanksTotal  Float      @default(0)

  @@index([predictionId])
}

/// One locked pick per viewer per prediction (first pick locks the side).
model PredictionEntry {
  id           String     @id @default(cuid())
  prediction   Prediction @relation(fields: [predictionId], references: [id], onDelete: Cascade)
  predictionId String
  optionId     String
  actorId      String
  actorName    String
  stakeThanks  Float      @default(0)
  createdAt    DateTime   @default(now())

  @@unique([predictionId, actorId])
  @@index([predictionId])
}

/// Per-viewer prediction track record for a channel — the "Oracle" leaderboard.
model Oracle {
  id         String   @id @default(cuid())
  channel    Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  channelId  String
  actorId    String
  actorName  String
  points     Int      @default(0)
  wins       Int      @default(0)
  losses     Int      @default(0)
  streak     Int      @default(0)
  bestStreak Int      @default(0)
  updatedAt  DateTime @updatedAt

  @@unique([channelId, actorId])
  @@index([channelId, points])
}
