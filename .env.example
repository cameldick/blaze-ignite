# ─── Blaze Ignite environment ───────────────────────────────────────────────
# Copy to .env and fill in. NEVER commit a filled .env.

# Postgres (managed: Neon / Supabase / RDS). Used by web + bridge.
DATABASE_URL="postgresql://user:pass@host:5432/blaze_ignite?schema=public"

# ─── Blaze API (confirmed from dev.blaze.stream/docs — THREE hosts) ──────────
# OAuth (PKCE; auth URL is generated server-side, not hand-built):
BLAZE_OAUTH_BASE="https://blaze.stream/bapi/oauth2"
# REST API base (event subscriptions, channels, users, chat, …):
BLAZE_REST_BASE="https://api.blaze.stream/v1"
# WebSocket EventSub:
BLAZE_WS_URL="https://blaze.stream"
BLAZE_WS_PATH="/ws"

# App credentials (register at https://dev.blaze.stream → Applications):
BLAZE_CLIENT_ID="your-app-client-id"
BLAZE_CLIENT_SECRET="your-app-client-secret"
# Confirmed scopes (only these 4 exist). users.read is required to subscribe to
# events; offline.access enables refresh; users.bot enables chat automation.
BLAZE_SCOPES="users.read offline.access channel.moderate users.bot"
BLAZE_REDIRECT_URI="http://localhost:3000/api/auth/blaze/callback"

# Event ingestion: auto (Socket.IO) | socketio | polling
EVENT_ADAPTER_MODE="auto"
POLLING_INTERVAL_MS="4000"

# ─── Crypto ──────────────────────────────────────────────────────────────────
# 32-byte base64 key for AES-256-GCM encryption of OAuth tokens at rest.
# Generate: openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=""

# ─── Bridge <-> web wiring ───────────────────────────────────────────────────
NEXT_PUBLIC_BRIDGE_URL="http://localhost:4000"
BRIDGE_PORT="4000"
# Shared secret for web -> bridge control calls. openssl rand -base64 32
BRIDGE_INTERNAL_SECRET=""

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Random string for signing session cookies. openssl rand -base64 32
AUTH_SESSION_SECRET=""

# ─── Pricing (optional) ──────────────────────────────────────────────────────
# $BLAZE→USD is read live from the Avalanche DEX (DexScreener). This is only a
# manual fallback used if that fetch ever fails.
BLAZE_USD_PRICE=""

# ─── Observability (optional) ────────────────────────────────────────────────
SENTRY_DSN=""
